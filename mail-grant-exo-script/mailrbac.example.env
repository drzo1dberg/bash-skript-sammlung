# mailrbac.example.env - Vorlage fuer die mail-* RBAC-Skripte.
#
# Kopieren und pro Ziel-Env ausfuellen, der .sh-Launcher sourcet die Datei
# anhand des ersten Arguments:
#   cp mailrbac.example.env mailrbac.test.env   # dann Werte eintragen
#   ./mail-mantle-appreg test
# Praezedenz: explizites -Param > mailrbac.<env>.env > Hardcoded-Default im .ps1.
# mailrbac.<env>.env NICHT committen (steht in .gitignore).

# Entra-Tenant + EXO-Organisation (.onmicrosoft.com-Domain)
MAILRBAC_TENANT_ID="00000000-0000-0000-0000-000000000000"
MAILRBAC_ORGANIZATION="contoso.onmicrosoft.com"

# Ziel-App-Registration / Enterprise App (nur diese App versendet Mail)
MAILRBAC_APP_ID="11111111-1111-1111-1111-111111111111"        # Application (client) ID
MAILRBAC_SP_OBJECT_ID="22222222-2222-2222-2222-222222222222"  # Enterprise App Object ID
MAILRBAC_APP_NAME="app-mailer-be"

# Zielpostfach und EXO-Management-Scope. Der Scope begrenzt die App auf genau
# dieses eine Postfach. Pro Postfach einen eigenen ScopeName waehlen.
MAILRBAC_TARGET_MAILBOX="service-mailbox@contoso.com"
MAILRBAC_SCOPE_NAME="SingleMailbox-Scope"

# Rollen, kommagetrennt. mantle vergibt MAILRBAC_ROLES scoped, revoke entzieht die
# org-weiten MAILRBAC_ROLES_TO_REVOKE.
MAILRBAC_ROLES="Application Mail.Send"
MAILRBAC_ROLES_TO_REVOKE="Mail.Send,Mail.ReadWrite,Mail.ReadBasic.All,Mail.Read"
