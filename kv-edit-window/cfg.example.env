# cfg.example.env - Vorlage fuer kv-edit-window.sh. Kopieren zu cfg.<env>.env
# (z.B. cfg.prod.env) und ausfuellen; das Skript sourcet cfg.<env>.env anhand
# des ersten Arguments. cfg.<env>.env NICHT committen (siehe .gitignore).
CFG_TENANT_ID="00000000-0000-0000-0000-000000000000"
CFG_ADMIN_IP="203.0.113.10"           # Egress-IP, die im Fenster freigeschaltet wird
CFG_KV_EDIT_UPN="admin@example.com"   # wer die Secrets setzen darf (bekommt die Rolle)
